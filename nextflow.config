docker.enabled=false
conda.enabled=true
process {
  withLabel: fastqc {
    cpus = 4
    memory = 2.GB
    conda = 'bioconda::fastqc'
  }
  withLabel: trimmomatic {
    cpus = 4
    memory = 2.GB
    conda = 'bioconda::trimmomatic'
  }
  withLabel: bwamem2 {
    cpus = 4
    memory = 2.GB
    conda = 'bioconda::bwa'
  }
}


